<IfModule mod_rewrite.c>
  Options -Multiviews
  RewriteEngine On
  # RewriteBase debe coincidir con tu carpeta real.
  # Si tu proyecto está en http://localhost/fichaqr/.
  # Podés dejarlo comentado (recomendado) o setearlo a /fichaqr/public.
  # RewriteBase /fichaqr/public
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
</IfModule>